# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_APP=run.py
FLASK_ENV=development

# Database
DATABASE_URL=sqlite:///crop_disease.db

# ============================================================
# IMPORTANT: API Keys for Real Disease Detection
# ============================================================
# 
# The system works in 3 modes:
# 1. MOCK MODE (No API key) - Returns fake data for testing
# 2. PLANT.ID MODE (Recommended) - Real, accurate disease detection
# 3. PLANTNET MODE (Alternative) - Basic plant identification
#
# To get REAL disease detection:
# 1. Go to https://web.plant.id/
# 2. Create a FREE account (100 requests/month)
# 3. Get your API key from the dashboard
# 4. Paste it below (remove the # to uncomment)
# 5. Restart the application
#
# See API_SETUP_GUIDE.md for detailed instructions
# ============================================================

# Plant.id API (RECOMMENDED - Best for crop diseases)
# Get your FREE key at: https://web.plant.id/
PLANT_ID_API_KEY=

# PlantNet API (Alternative)
# Get your key at: https://my.plantnet.org/
PLANTNET_API_KEY=

# Upload Configuration
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=app/static/uploads
ALLOWED_EXTENSIONS=png,jpg,jpeg,gif

# Admin Configuration
ADMIN_EMAIL=admin@cropdisease.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
